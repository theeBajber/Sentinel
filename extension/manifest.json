{
  "manifest_version": 2,
  "name": "Sentinel - Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time phishing protection powered by Sentinel. Automatically scans URLs and blocks malicious websites.",
  "author": "Sentinel Team",
  "homepage_url": "https://sentinel-zeta-pied.vercel.app",

  "permissions": [
    "activeTab",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "notifications",
    "<all_urls>",
    "http://localhost:3000/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Sentinel Protection",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    "blocked.html",
    "setup.html",
    "setup.js",
    "icons/*.png"
  ],

  "content_security_policy": "script-src 'self'; object-src 'self'",

  "browser_specific_settings": {
    "gecko": {
      "id": "sentinel@phishing-detector.local",
      "strict_min_version": "109.0"
    }
  }
}
