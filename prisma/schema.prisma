generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id(map: "AdminUser_pkey") @default(cuid())
  email         String         @unique(map: "AdminUser_email_key")
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  name          String
  apiKeys       ApiKey[]
  detectionLogs DetectionLog[]
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  permissions String[]
  isActive    Boolean   @default(true)
  lastUsed    DateTime?
  createdAt   DateTime  @default(now())
  createdBy   String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model ThreatEntry {
  id        String   @id @default(cuid())
  pattern   String
  isRegex   Boolean  @default(false)
  severity  String
  source    String
  notes     String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pattern])
}

model DetectionLog {
  id               String   @id @default(cuid())
  url              String
  domain           String?
  verdict          String
  score            Int
  reasons          String
  matchedThreatIds String?
  threatType       String?
  confidence       Int?
  clientIp         String?
  userAgent        String?
  source           String   @default("extension")
  apiKeyId         String?
  tabId            Int?
  createdAt        DateTime @default(now())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([verdict])
  @@index([domain])
  @@index([apiKeyId])
}
